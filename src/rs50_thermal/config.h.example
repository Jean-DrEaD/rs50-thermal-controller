cat > src/rs50_thermal/config.h.example << 'EOF'
#pragma once

// ===== Wi-Fi (preenchido via GitHub Secrets) =====
#define WIFI_SSID "__WIFI_SSID__"
#define WIFI_PASS "__WIFI_PASS__"

// ===== Pinos =====
#define PIN_NTC    34
#define PIN_PWM    25
#define PIN_RELAY  26
#define PIN_CTRL   27

// ===== PWM =====
#define PWM_CHANNEL_FAN 0
#define PWM_FREQ        25000
#define PWM_RESOLUTION  8
#define PWM_MIN         0
#define PWM_MAX         255

// ===== NTC =====
#define NTC_SERIES_R    10000.0f
#define NTC_NOMINAL_R   10000.0f
#define NTC_NOMINAL_T   298.15f
#define NTC_BETA        3950.0f
#define ADC_MAX         4095.0f
#define THERMAL_OFFSET  0.0f

// ===== Temperaturas =====
#define TEMP_IDLE          35.0f
#define TEMP_WARMING       45.0f
#define TEMP_WARNING       60.0f
#define TEMP_CRITICAL      75.0f
#define THERMAL_HYSTERESIS 1.5f
#define TEMP_FILTER_ALPHA  0.2f

// ===== Tempos / Rede =====
#define SAMPLE_INTERVAL_MS    500
#define TELEMETRY_INTERVAL_MS 1000
#define UDP_PORT              4210
#define UDP_BROADCAST_IP      IPAddress(255,255,255,255)
EOF
