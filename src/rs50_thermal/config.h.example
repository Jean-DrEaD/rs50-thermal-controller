#ifndef CONFIG_H
#define CONFIG_H

// =====================================================
// RS50 Thermal Controller - Configuração Global
// =====================================================

// ---------- Firmware Version ----------
#define FW_VERSION        "3.3.13"

// ---------- Wi-Fi ----------
// ⚠️ NÃO COMMITAR credenciais reais — usar config.h.example como template
#define WIFI_SSID         "SEU_SSID_AQUI"
#define WIFI_PASS         "SUA_SENHA_AQUI"
#define WIFI_HOSTNAME     "rs50"

// ===== OTA / Admin =====
#define OTA_HOSTNAME    "rs50-thermal"
#define OTA_PASSWORD    "troque-isto"

// ---------------------------------------------------------------------------
// Network / Telemetry (UDP broadcast for SimHub)
// ---------------------------------------------------------------------------
#ifndef UDP_HOST
  #define UDP_HOST "255.255.255.255"   // broadcast default (safe public)
#endif
#ifndef UDP_PORT
  #define UDP_PORT 33333
#endif

// ===== MQTT (reservado — não usado em v3.x) =====
#define MQTT_HOST       "192.168.1.100"
#define MQTT_PORT       1883
#define MQTT_USER       ""
#define MQTT_PASS       ""

// ---------- Portas de rede ----------
#define WEB_PORT          80
#define WS_PORT           81
#define UDP_PORT          33333

// ---------- Pinos ESP32-S3-Zero ----------
// ⚠️ GPIO 21 reservado (LED RGB onboard) — NÃO USAR
#define PIN_NTC           1
#define PIN_RELAY         4
#define PIN_PWM           5
#define PIN_WS2812        9

// ---------- WS2812 / Status LEDs ----------
#define LED_COUNT         5
#define LED_BRIGHTNESS    64

// ---------- PWM ----------
#define PWM_CHANNEL_FAN   0
#define PWM_FREQ          25000
#define PWM_RESOLUTION    8
#define PWM_MIN           0
#define PWM_MAX           100

// ---------- NTC 100k B3950 (Steinhart-Hart) ----------
#define ADC_MAX           4095.0f
#define NTC_SERIES_R      100000.0f
#define NTC_NOMINAL_R     100000.0f
#define NTC_NOMINAL_T     298.15f
#define NTC_BETA          3950.0f
#define THERMAL_OFFSET    0.0f

// ---------- Filtragem ----------
#define TEMP_FILTER_ALPHA 0.2f
#define SAMPLE_INTERVAL_MS 500
#define TELEMETRY_INTERVAL_MS 1000

// ---------- Limiares térmicos (°C) ----------
// Faixas distintas para a máquina de estados funcionar com histerese:
//   IDLE     → WARMING em T > 40°C
//   WARMING  → WARNING em T > 60°C
//   WARNING  → CRITICAL em T > 68°C
//   CRITICAL → WARNING em T < 63°C (TEMP_RESTART, histerese de 5°C)
#define TEMP_IDLE         40.0f
#define TEMP_WARMING      45.0f      // limiar de saída do IDLE (com histerese)
#define TEMP_WARNING      60.0f
#define TEMP_CRITICAL     68.0f
#define TEMP_RESTART      63.0f
#define TEMP_MIN          TEMP_IDLE
#define TEMP_MAX          TEMP_CRITICAL
#define THERMAL_HYSTERESIS 2.0f      // pequena (5°C grande só entre CRITICAL→WARNING via TEMP_RESTART)

// ---------- Relé ----------
extern bool relayOn;

#endif // CONFIG_H
