# ═══════════════════════════════════════════════════════════
# 🚫 KiCad — ABANDONADO (use Fritzing como fonte oficial)
# ═══════════════════════════════════════════════════════════
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups/
*-cache*
*-bak
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
*.net
*.dsn
*.ses
*.kicad_prl
**/*-backups/*.zip

# ═══════════════════════════════════════════════════════════
# 🎨 Fritzing — fonte oficial (mantém .fzz versionado)
# ═══════════════════════════════════════════════════════════
*.fz.bak
*.fzz.bak
backup/
**/extracted/
**/Diagram/

# ═══════════════════════════════════════════════════════════
# 💻 Arduino / PlatformIO
# ═══════════════════════════════════════════════════════════
*.elf
*.hex
*.map
*.eep
build/
.pio/
.pioenvs/
.piolibdeps/

# ═══════════════════════════════════════════════════════════
# 🔐 Secrets — NUNCA commitar credenciais
# ═══════════════════════════════════════════════════════════
src/**/secrets.h
src/**/credentials.h
*.env
.env.local

# ═══════════════════════════════════════════════════════════
# 🖥️ Sistema operacional
# ═══════════════════════════════════════════════════════════
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.DS_Store
.AppleDouble
.LSOverride
._*
.fuse_hidden*
.directory
.Trash-*

# ═══════════════════════════════════════════════════════════
# 📝 Editores
# ═══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# ═══════════════════════════════════════════════════════════
# 🤖 Scripts antigos (ignora, nao apaga do disco)
# ═══════════════════════════════════════════════════════════
scripts/create-schematic.ps1
scripts/schematic-builder.ps1
scripts/*.ps1.bak
# ═══════════════════════════════════════════════════════════
# 📜 VS Code Local History (extensao xyz.local-history)
# ═══════════════════════════════════════════════════════════
.history/
**/.history/
.backup/
**/.backup/
# ═══════════════════════════════════════════════════════════
# 🔧 Arduino IDE — duplicatas e backups acidentais
# ═══════════════════════════════════════════════════════════
*.ino.txt
src/**/*.ino.txt
*.ino.bak
*.ino.orig
build/